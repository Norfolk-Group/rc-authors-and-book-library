# ─────────────────────────────────────────────────────────────────────────────
# RC Library — environment variables
#
# Copy this file to `.env` (which is git-ignored) and fill in real values for
# local dev. On a host (Railway/Render/etc.), set these in the platform's
# environment-variables UI instead of committing them.
#
# The server loads `.env` automatically (server/_core/index.ts → import "dotenv/config").
#
# Legend:  [REQUIRED] app won't work without it   [OPTIONAL] feature degrades gracefully if unset
# ─────────────────────────────────────────────────────────────────────────────

# ── Core / runtime ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000                                   # [OPTIONAL] server port (default 3000)
JWT_SECRET=                                 # [REQUIRED] signs session cookies (use a long random string)

# ── Databases (already external/managed — these travel to any host) ───────────
DATABASE_URL=                               # [REQUIRED] MySQL/TiDB connection string
NEON_DATABASE_URL=                          # [REQUIRED for search] Neon Postgres (pgvector) connection string

# ── Auth (currently Manus OAuth — MUST be replaced when off the Manus platform) ─
VITE_APP_ID=                                # [REQUIRED for login] Manus OAuth app id
OAUTH_SERVER_URL=                           # [REQUIRED for login] OAuth server base URL
OWNER_OPEN_ID=                              # [OPTIONAL] owner user id (admin bootstrap)

# ── File storage (currently Manus Forge S3 — replace with AWS S3 / Cloudflare R2) ─
BUILT_IN_FORGE_API_URL=                     # Manus S3 endpoint (replace when migrating storage)
BUILT_IN_FORGE_API_KEY=                     # Manus S3 key (replace when migrating storage)

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                          # Claude — enrichment, Digital Me, classification
GEMINI_API_KEY=                             # Gemini — 1536-dim embeddings + vision
PERPLEXITY_API_KEY=                         # Perplexity Sonar — bio enrichment + Web Research answers
EXA_API_KEY=                                # Exa — neural web search (/research + news enrichment)

# ── Enrichment / content sources ([OPTIONAL] — each feature degrades if unset) ─
TAVILY_API_KEY=                             # Web image search for avatars
REPLICATE_API_TOKEN=                        # Replicate flux — AI avatar generation
APIFY_API_TOKEN=                            # Amazon cover / CNN / TED scraping
YOUTUBE_API_KEY=                            # YouTube channel stats
RAPIDAPI_KEY=                               # Yahoo Finance + LinkedIn stats
TWITTER_BEARER_TOKEN=                       # Twitter/X follower counts (Basic plan)
GOOGLE_BOOKS_API_KEY=                       # Google Books metadata
OMDB_API_KEY=                               # OMDb (film/TV adaptations)
DPLA_API_KEY=                               # Digital Public Library of America
APOLLO_API_KEY=                             # Apollo.io professional profiles
QUARTR_API_KEY=                             # Quartr earnings transcripts
INSTAGRAM_ACCESS_TOKEN=                     # Instagram profile stats

# ── Dropbox (cloud sync) ──────────────────────────────────────────────────────
DROPBOX_APP_KEY=                            # Dropbox OAuth app key
DROPBOX_APP_SECRET=                         # Dropbox OAuth app secret
DROPBOX_REFRESH_TOKEN=                      # Long-lived refresh token (auto-refreshes access token)
DROPBOX_ACCESS_TOKEN=                       # [OPTIONAL] short-lived static token fallback
DROPBOX_BACKUP_FOLDER=                      # Backup folder path
DROPBOX_INBOX_FOLDER=                       # Books inbox folder path
DROPBOX_AUTHORS_FOLDER=                     # Authors inbox folder path

# ── Tests ([OPTIONAL]) ────────────────────────────────────────────────────────
# RUN_LIVE_TESTS=1                          # opt in to live-API integration tests (off by default)
